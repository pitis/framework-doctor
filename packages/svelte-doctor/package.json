{
  "name": "svelte-doctor",
  "version": "1.0.0",
  "description": "Diagnose and improve Svelte codebase health",
  "keywords": [
    "diagnostics",
    "linter",
    "svelte",
    "sveltekit",
    "performance"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "svelte-doctor": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "rimraf dist && cross-env NODE_ENV=production tsdown",
    "lint": "oxlint src tests",
    "lint:fix": "oxlint --fix src tests",
    "typecheck": "tsc --noEmit",
    "test": "pnpm build && vitest run"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "knip": "^5.83.1",
    "oxlint": "^1.49.0",
    "picocolors": "^1.1.1",
    "svelte-check": "^4.1.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "cross-env": "^10.1.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.2",
    "vitest": "^4.0.8"
  }
}
