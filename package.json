{
  "name": "svelte-doctor",
  "private": true,
  "homepage": "https://github.com/your-org/svelte-doctor#readme",
  "license": "MIT",
  "description": "Monorepo for Svelte Doctor",
  "scripts": {
    "build": "turbo run build",
    "build:doctor": "turbo run build --filter=svelte-doctor",
    "dev": "turbo run dev",
    "dev:doctor": "turbo run dev --filter=svelte-doctor",
    "lint": "turbo run lint",
    "lint:doctor": "turbo run lint --filter=svelte-doctor",
    "lint:fix": "turbo run lint:fix --filter=svelte-doctor",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:doctor": "turbo run test --filter=svelte-doctor --concurrency=1",
    "quality:check": "turbo run lint typecheck test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/node": "^25.3.0",
    "oxlint": "^1.49.0",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  },
  "packageManager": "pnpm@10.29.1"
}
